{
  "name": "sanastopeli",
  "version": "1.0.0",
  "description": "Sanastopeli – harjoittele sanastoa eri kielillä",
  "author": "Sanastopeli",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "icon": "node scripts/generate-icon.js",
    "pack": "npm run icon && electron-builder --dir",
    "dist": "npm run icon && electron-builder",
    "dist:win": "npm run icon && electron-builder --win"
  },
  "build": {
    "appId": "fi.sanastopeli.app",
    "productName": "Sanastopeli",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "forceCodeSigning": false,
      "signingHashAlgorithms": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "installerSidebar": "assets/installer-sidebar.bmp",
      "installerHeader": "assets/installer-header.bmp",
      "language": "1035",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sanastopeli"
    },
    "extraResources": [
      {
        "from": "packages",
        "to": "packages",
        "filter": ["**/*.json"]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/.bin"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
